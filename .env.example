# Required Core Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_system"
JWT_SECRET="your-jwt-secret-key"
NODE_ENV="development"

# Docker Database Configuration (Only needed if using Docker)
USE_LOCAL_DB="true"
DOCKER_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_system"

# Vercel Configuration (Only needed for production/preview deployments)
NEXT_PUBLIC_VERCEL_ENV="development"
NEXT_PUBLIC_VERCEL_BRANCH_URL="your-preview-url.vercel.app"

# Admin Configuration
ADMIN_EMAIL="admin@example.com"

# Email Configuration (Optional - Only if email verification is enabled)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@example.com"
SMTP_SECURE="false"

# Resend.com Configuration (Optional - Only for production email sending)
RESEND_API_KEY="re_123456789"

# Neon Database Configuration
DATABASE_URL_UNPOOLED=your_neon_unpooled_url

# Neon Connection Parameters
PGHOST=your_neon_host
PGHOST_UNPOOLED=your_neon_unpooled_host
PGUSER=your_neon_user
PGDATABASE=your_neon_database
PGPASSWORD=your_neon_password

# Vercel Postgres Configuration
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=verceldb

# Environment
NODE_ENV=development

# Other environment variables...
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-app-specific-password
NEXT_PUBLIC_APP_URL=http://localhost:3000 